{
  "version": 2,
  "builds": [
    {
      "src": "BACKEND/backend/api/index.php",
      "use": "vercel-php",
      "config": {
        "installCommand": "composer install --no-dev --prefer-dist",
        "excludeFiles": [
          "BACKEND/backend/node_modules/**",
          "FRONTEND/**"
        ]
      }
    },
    {
      "src": "FRONTEND/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/BACKEND/backend/api/index.php"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}