{
  "version": 2,
  "builds": [
    {
      "src": "BACKEND/backend/api/index.php",
      "use": "@vercel/php"
    },
    {
      "src": "FRONTEND/frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/BACKEND/backend/api/index.php"
    },
    {
      "source": "/(.*)",
      "destination": "/FRONTEND/frontend/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/FRONTEND/frontend/dist/index.html"
    }
  ]
}