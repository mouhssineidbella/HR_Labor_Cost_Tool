{
  "version": 2,
  "builds": [
    {
      "src": "BACKEND/backend/api/index.php",
      "use": "vercel-php",
      "config": {
        "installCommand": "composer install --no-dev --prefer-dist",
        "excludeFiles": [
          "BACKEND/backend/node_modules/**",
          "FRONTEND/**"
        ]
      }
    },
    {
      "src": "FRONTEND/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "FRONTEND/frontend/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/BACKEND/backend/api/index.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/FRONTEND/frontend/dist/index.html"
    }
  ]
}